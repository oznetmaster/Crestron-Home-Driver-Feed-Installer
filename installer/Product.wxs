<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	 xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
	<Package Name="Crestron Home Driver Feed Installer"
		   Manufacturer="Neil Colvin"
		   Version="1.0.6"
		   UpgradeCode="C1F9F8C0-56F2-4E51-9A70-6F1F340F7F3A"
		   Language="1033"
		   Scope="perMachine"
		   InstallerVersion="500"
		   Compressed="yes">

	<MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
	<MediaTemplate EmbedCab="yes" />

	<Icon Id="AppIcon.ico" SourceFile="..\src\Resources\variant_1_blue_light_transparent.ico" />
	<Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
	<Property Id="ARPURLINFOABOUT" Value="https://github.com/oznetmaster/Crestron-Home-Driver-Feed-Installer" />
	<Property Id="ARPHELPLINK" Value="https://github.com/oznetmaster/Crestron-Home-Driver-Feed-Installer" />
	<Property Id="MSIFASTINSTALL" Value="7" />
	<Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
	<WixVariable Id="WixUIBannerBmp" Value="Assets\WixUIBanner.bmp" />
	<WixVariable Id="WixUIDialogBmp" Value="Assets\WixUIDialog.bmp" />
	<WixVariable Id="WixUILicenseRtf" Value="Assets\License.rtf" />

	<StandardDirectory Id="ProgramFiles64Folder">
	  <Directory Id="INSTALLFOLDER" Name="Crestron Home Driver Feed Installer">
		<Component Id="MainExecutableComponent" Guid="5F1F2737-8BA7-4E84-86FE-611A6D6DFDE8">
		  <File Id="MainExecutableFile" Source="$(var.PublishDir)Crestron Home Driver Feed Installer.exe" KeyPath="yes" Checksum="yes" />
		  <RegistryValue Root="HKLM" Key="Software\Neil Colvin\CrestronHomeDriverFeedInstaller" Name="Installed" Type="integer" Value="1" KeyPath="no" />
		</Component>
	  </Directory>
	</StandardDirectory>

	<StandardDirectory Id="ProgramMenuFolder">
	  <Directory Id="ProgramMenuDir" Name="Crestron Home Driver Feed Installer">
		<Component Id="StartMenuShortcutComponent" Guid="6FEA2BF3-0DCD-4C90-99C3-116A8010B83B">
		  <Shortcut Id="ApplicationStartMenuShortcut"
					Name="Crestron Home Driver Feed Installer"
					WorkingDirectory="INSTALLFOLDER"
					Icon="AppIcon.ico"
					Advertise="no"
					Target="[INSTALLFOLDER]Crestron Home Driver Feed Installer.exe" />
		  <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
		  <RegistryValue Root="HKCU" Key="Software\Neil Colvin\CrestronHomeDriverFeedInstaller" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
		</Component>
	  </Directory>
	</StandardDirectory>

	<StandardDirectory Id="DesktopFolder">
	  <Component Id="DesktopShortcutComponent" Guid="D046F56E-1E6B-405A-957E-9FF640E4E033">
		<Shortcut Id="ApplicationDesktopShortcut"
				  Name="Crestron Home Driver Feed Installer"
				  WorkingDirectory="INSTALLFOLDER"
				  Icon="AppIcon.ico"
				  Advertise="no"
				  Target="[INSTALLFOLDER]Crestron Home Driver Feed Installer.exe" />
		<RegistryValue Root="HKCU" Key="Software\Neil Colvin\CrestronHomeDriverFeedInstaller" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
	  </Component>
	</StandardDirectory>

	<Feature Id="MainFeature" Title="Crestron Home Driver Feed Installer" Level="1">
	  <ComponentRef Id="MainExecutableComponent" />
	  <ComponentRef Id="StartMenuShortcutComponent" />
	  <ComponentRef Id="DesktopShortcutComponent" />
	  <Files Include="$(var.PublishDir)**" Directory="INSTALLFOLDER">
		<Exclude Files="$(var.PublishDir)Crestron Home Driver Feed Installer.exe" />
	  </Files>
	</Feature>

	<ui:WixUI Id="WixUI_InstallDir" />
  </Package>
</Wix>

<Window x:Class="CrestronHomeDriverFeedInstaller.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False">
    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding ApplicationName}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Grid.Row="1" Text="{Binding VersionText}" Margin="0,0,0,16" />
            <TextBlock Grid.Row="2" Text="{Binding TargetFrameworkText}" Margin="0,0,0,6" />
            <TextBlock Grid.Row="3" Text="{Binding CopyrightText}" Margin="0,0,0,6" TextWrapping="Wrap" MaxWidth="420" />
            <TextBlock Grid.Row="4" Margin="0,0,0,16" TextWrapping="Wrap" MaxWidth="420">
                <Run Text="Repository: " />
                <Hyperlink NavigateUri="{Binding RepositoryUri, Mode=OneWay}" RequestNavigate="RepositoryLink_OnRequestNavigate">
                    <Run Text="{Binding RepositoryUrl, Mode=OneWay}" />
                </Hyperlink>
            </TextBlock>
            <TextBlock Grid.Row="5" Text="{Binding TrademarkDisclaimerText}" Margin="0,0,0,16" TextWrapping="Wrap" MaxWidth="420" />
            <Button Grid.Row="6" Content="OK" Width="90" HorizontalAlignment="Right" IsDefault="True" Click="OkButton_OnClick" />
        </Grid>
    </Border>
</Window>

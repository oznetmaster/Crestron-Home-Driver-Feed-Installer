<Window x:Class="CrestronHomeDriverFeedInstaller.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Crestron Home Driver Feed Installer" Height="760" Width="1200" MinHeight="700" MinWidth="1100">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="RoyalBlue" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                    <Setter Property="Foreground" Value="Red" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" MinWidth="400" />
            <ColumnDefinition Width="3*" MinWidth="300" />
            <ColumnDefinition Width="3*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="NuGet feed" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Feed URL" Margin="0,0,0,4" />
                <TextBlock Text="Search" Grid.Row="1" Margin="0,8,0,4" />

                <TextBox Grid.Column="1" Grid.ColumnSpan="2" Margin="8,0,0,0" Text="{Binding FeedUrl, UpdateSourceTrigger=PropertyChanged}" ToolTip="NuGet feed URL used for package search and download." />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="8,8,8,0" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" ToolTip="Package ID or text to search for in the configured feed." />
                <Button Grid.Row="1" Grid.Column="2" Margin="0,8,0,0" Padding="12,4" Command="{Binding SearchCommand}" Content="Search" ToolTip="Search the configured feed for matching packages." />
                <CheckBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,8,0,0" IsChecked="{Binding OnlyV1CompliantPackages}" Content="Only search for v1 compliant packages" ToolTip="Limit results to packages that match the v1 driver package requirements." />
            </Grid>
        </GroupBox>

        <GroupBox Header="Processor connection" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Processor" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Grid.ColumnSpan="2" Margin="8,0,12,8" ItemsSource="{Binding SavedProcessors}" SelectedItem="{Binding SelectedSavedProcessor}" DisplayMemberPath="Label" ToolTip="Select a saved processor connection to restore its details." />
                <Button Grid.Column="3" Margin="0,0,8,8" Padding="12,4" Command="{Binding DiscoverProcessorsCommand}" Content="Discover" ToolTip="Search the network for available processors." />
                <Button Grid.Column="4" Margin="0,0,8,8" Padding="12,4" Command="{Binding AddProcessorCommand}" Content="New" ToolTip="Clear the current processor details so you can add a new one." />
                <Button Grid.Column="5" Margin="0,0,0,8" Padding="12,4" Command="{Binding DeleteProcessorCommand}" Content="Delete" ToolTip="Delete the selected saved processor connection." />

                <TextBlock Grid.Row="1" Text="Display name" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" Margin="8,0,0,8" Text="{Binding ProcessorDisplayName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Friendly name shown in the saved processor list." />

                <TextBlock Grid.Row="2" Text="Host" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" Margin="8,0,0,8" Text="{Binding ProcessorHost, UpdateSourceTrigger=PropertyChanged}" ToolTip="Host name or IP address of the target processor." />

                <TextBlock Grid.Row="3" Text="Username" VerticalAlignment="Center" />
                <TextBox Grid.Row="3" Grid.Column="1" Margin="8,0,12,8" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" ToolTip="Username used for processor upload." />
                <TextBlock Grid.Row="3" Grid.Column="2" Text="Password" VerticalAlignment="Center" />
                <PasswordBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="3" Margin="8,0,0,8" PasswordChanged="PasswordBox_OnPasswordChanged" ToolTip="Password used for processor upload." />

                <CheckBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="5" Margin="8,0,0,0" VerticalAlignment="Center" IsChecked="{Binding RememberCredentials}" Content="Remember credentials for this processor" ToolTip="Save the username and password for the selected processor on this computer." />
            </Grid>
        </GroupBox>

        <GroupBox Header="Packages" Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="180" />
                </Grid.RowDefinitions>

                <DataGrid x:Name="SearchResultsDataGrid" ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedPackage}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow" SelectionChanged="SearchResultsDataGrid_OnSelectionChanged" PreviewMouseLeftButtonDown="DataGrid_OnPreviewMouseLeftButtonDown" ToolTip="Search results. Use Ctrl-click or Shift-click to select multiple packages.">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="RoyalBlue" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="2*" />
                        <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="*" />
                        <DataGridTextColumn Header="Authors" Binding="{Binding Authors}" Width="1.5*" />
                        <DataGridTextColumn Header="Downloads" Binding="{Binding DownloadCount}" Width="*" />
                        <DataGridTemplateColumn Header="Info" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                        <Button Width="28" Height="24" Padding="0" FontSize="14" FontWeight="SemiBold" PreviewMouseLeftButtonDown="InfoButton_OnPreviewMouseLeftButtonDown" Click="PackageInfoButton_OnClick" ToolTip="Package information">
                                            <TextBlock Text="ⓘ" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="1" Margin="0,8,0,0" Padding="12,6" MinWidth="132" HorizontalAlignment="Left" Command="{Binding InspectCommand}" ToolTip="Download the selected package or packages into the local cache and inspect the extracted driver package.">
                    <TextBlock Text="{Binding InspectButtonText}" TextWrapping="Wrap" TextAlignment="Center" />
                </Button>

                <TextBlock Grid.Row="2" Margin="0,12,0,4" FontWeight="SemiBold" Text="Cached packages" />
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="CachedPackagesDataGrid" ItemsSource="{Binding CachedPackages}" SelectedItem="{Binding SelectedCachedPackage}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow" SelectionChanged="CachedPackagesDataGrid_OnSelectionChanged" PreviewMouseLeftButtonDown="DataGrid_OnPreviewMouseLeftButtonDown" ToolTip="Cached packages. Use Ctrl-click or Shift-click to select multiple entries.">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="RoyalBlue" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding HasNewerVersionAvailable}" Value="True">
                                        <Setter Property="Background" Value="LightGoldenrodYellow" />
                                        <Setter Property="ToolTip" Value="A newer driver version is available." />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Package" Binding="{Binding PackageId}" Width="4.5*" />
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="*" />
                            <DataGridTemplateColumn Header="Info" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="28" Height="24" Padding="0" FontSize="14" FontWeight="SemiBold" PreviewMouseLeftButtonDown="InfoButton_OnPreviewMouseLeftButtonDown" Click="CachedPackageInfoButton_OnClick" ToolTip="Cached package information">
                                            <TextBlock Text="ⓘ" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <UniformGrid Grid.Row="1" Margin="0,8,0,0" Columns="3">
                        <Button Padding="8,6" MinWidth="0" Margin="0,0,4,0" Command="{Binding UseCachedPackageCommand}" ToolTip="Upload the selected cached package to the selected processor.">
                            <TextBlock Text="{Binding UseCachedPackageButtonText}" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                        <Button Margin="4,0" Padding="8,6" MinWidth="0" Command="{Binding UpdateCachedPackageCommand}" ToolTip="Replace selected cached packages that have updates available with the latest versions.">
                            <TextBlock Text="{Binding UpdateCachedPackageButtonText}" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                        <Button Margin="4,0,0,0" Padding="8,6" MinWidth="0" Click="DeleteCachedPackagesButton_OnClick" IsEnabled="{Binding CanDeleteCachedPackages}" ToolTip="Remove the selected packages from the local cache.">
                            <TextBlock Text="{Binding DeleteCachedPackageButtonText}" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                    </UniformGrid>
                </Grid>
            </Grid>
        </GroupBox>

        <GroupBox Header="Package details" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Selected package" Margin="0,0,0,8" FontWeight="SemiBold" />
                <TextBox Grid.Row="1" Margin="0,0,0,8" Text="{Binding SelectedPackageDetails}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" IsReadOnly="True" MinHeight="120" ToolTip="Details for the selected package from the feed." />
                <TextBlock Grid.Row="2" Text="Cached package" Margin="0,0,0,8" FontWeight="SemiBold" />
                <TextBox Grid.Row="3" Margin="0,0,0,8" Text="{Binding SelectedCachedPackageDetails}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" IsReadOnly="True" MinHeight="90" ToolTip="Details for the selected cached package." />
                <TextBlock Grid.Row="4" Text="Staged driver package" Margin="0,0,0,8" FontWeight="SemiBold" />
                <Grid Grid.Row="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBox Text="{Binding StagedDriverPackagePath}" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Margin="0,0,0,8" ToolTip="Path to the currently staged driver package." />
                    <TabControl Grid.Row="1">
                        <TabItem>
                            <TabItem.Header>
                                <TextBlock Text="Entries" ToolTip="Entries in the staged driver package." />
                            </TabItem.Header>
                            <TextBox Text="{Binding PackageEntries}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" IsReadOnly="True" />
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <TextBlock Text="Manifest" ToolTip="Contents of the staged crestron-driver-package.json file." />
                            </TabItem.Header>
                            <TextBox Text="{Binding CrestronDriverPackageJsonContent}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" IsReadOnly="True" />
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <TextBlock Text="README" ToolTip="Contents of the staged README.md file." />
                            </TabItem.Header>
                            <TextBox Text="{Binding ReadmeContent}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" IsReadOnly="True" />
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </GroupBox>

        <GroupBox Header="Discovery diagnostics" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8" Visibility="{Binding ShowDiscoveryDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="8">
                <TextBox Height="120" MaxHeight="120" Text="{Binding DiscoveryDiagnostics}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" IsReadOnly="True" ToolTip="Detailed processor discovery messages." />
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
            <CheckBox DockPanel.Dock="Right" Margin="0,0,12,0" VerticalAlignment="Center" IsChecked="{Binding ShowDiscoveryDiagnostics}" Content="Show discovery diagnostics" ToolTip="Show or hide the discovery diagnostics panel." />
            <TextBlock VerticalAlignment="Center" Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,12,0" Style="{StaticResource StatusTextStyle}" ToolTip="Current application status." />
        </DockPanel>
    </Grid>
</Window>

